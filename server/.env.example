# ---------------------------------------------------------------------------
# Server configuration
# Copy this file to `.env` and adjust as needed:  cp .env.example .env
# ---------------------------------------------------------------------------

# Node environment: development | production | test
NODE_ENV=development

# Port the API listens on
PORT=4000

# MongoDB connection string.
# LEAVE THIS BLANK to run with a zero-config in-memory MongoDB (great for a
# quick local demo — no database install required). Set it to a real MongoDB
# URI (local mongod or MongoDB Atlas) for persistent data.
#   Local example:  mongodb://127.0.0.1:27017/event-booking
#   Atlas example:  mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/event-booking
MONGO_URI=

# Secret used to sign JWT auth tokens. REQUIRED in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-only-secret-change-me

# How long an auth session lasts (zeit/ms format)
JWT_EXPIRES_IN=7d

# Origin of the frontend, used for CORS + cookie settings
CLIENT_ORIGIN=http://localhost:5173

# Name of the auth cookie
COOKIE_NAME=ebs_token

# Cookie security flags. Leave unset to derive sensible values from NODE_ENV
# (prod => Secure + SameSite=None for cross-site; dev => SameSite=Lax over http).
# Override when serving same-origin over http (e.g. Docker): COOKIE_SECURE=false
#   COOKIE_SECURE: true | false
#   COOKIE_SAMESITE: lax | strict | none
COOKIE_SECURE=
COOKIE_SAMESITE=

# bcrypt work factor (10–12 is a sensible range)
BCRYPT_ROUNDS=12
